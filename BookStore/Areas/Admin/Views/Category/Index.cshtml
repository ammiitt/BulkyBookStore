
@model IEnumerable<Category>

<div class="container">
    <div class="row pt-4 pb-2">
        <div class="col-6">
            <h1>
                Category List
            </h1>
        </div>
        <div class="col-6 text-end pt-1">
            <a asp-controller="Category" asp-action="Create" class="btn btn-outline-info"><i class="bi bi-plus-circle-fill"> Add New Category</i></a>
        </div>
    </div>

    <table class="table table-hover table-dark">
        <thead>
            <tr>
                <th>
                    Name
                </th>
                <th>
                    Display Order
                </th>
                <th>
                    Actions
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr >
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.DisplayOrder)
                    </td>
                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Category" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>
                            <a asp-controller="Category" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger mx-2">
                                <i class="bi bi-trash-fill"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    
</div>


 