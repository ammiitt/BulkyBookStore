@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Register";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="card border-0 shadow-lg">

                <div class="card-header bg-primary text-white text-center py-3">
                    <h3 class="mb-0">
                        Continue with @Model.ProviderDisplayName
                    </h3>
                </div>

                <div class="card-body p-4">

                    <p class="text-muted text-center mb-4">
                        You’ve successfully authenticated with
                        <strong>@Model.ProviderDisplayName</strong>.
                        Complete your profile to continue.
                    </p>

                    <form asp-page-handler="Confirmation"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3"
                             role="alert"></div>

                        <div class="row g-3">

                            <!-- Email -->
                            <div class="col-12 form-floating">
                                <input asp-for="Input.Email"
                                       class="form-control border-0 shadow"
                                       placeholder="Email" />
                                <label asp-for="Input.Email"></label>
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>

                            <!-- Name -->
                            <div class="col-12 form-floating">
                                <input asp-for="Input.Name"
                                       class="form-control border-0 shadow"
                                       placeholder="Full Name" />
                                <label asp-for="Input.Name"></label>
                                <span asp-validation-for="Input.Name" class="text-danger"></span>
                            </div>

                            <!-- Phone -->
                            <div class="col-md-6 form-floating">
                                <input asp-for="Input.PhoneNumber"
                                       class="form-control border-0 shadow"
                                       placeholder="Phone" />
                                <label asp-for="Input.PhoneNumber"></label>
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                            </div>

                            <!-- Address -->
                            <div class="col-md-6 form-floating">
                                <input asp-for="Input.StreetAddress"
                                       class="form-control border-0 shadow"
                                       placeholder="Street" />
                                <label asp-for="Input.StreetAddress"></label>
                                <span asp-validation-for="Input.StreetAddress" class="text-danger"></span>
                            </div>

                            <!-- City -->
                            <div class="col-md-6 form-floating">
                                <input asp-for="Input.City"
                                       class="form-control border-0 shadow"
                                       placeholder="City" />
                                <label asp-for="Input.City"></label>
                                <span asp-validation-for="Input.City" class="text-danger"></span>
                            </div>

                            <!-- State -->
                            <div class="col-md-6 form-floating">
                                <input asp-for="Input.State"
                                       class="form-control border-0 shadow"
                                       placeholder="State" />
                                <label asp-for="Input.State"></label>
                                <span asp-validation-for="Input.State" class="text-danger"></span>
                            </div>

                            <!-- Postal -->
                            <div class="col-md-6 form-floating">
                                <input asp-for="Input.PostalCode"
                                       class="form-control border-0 shadow"
                                       placeholder="Postal Code" />
                                <label asp-for="Input.PostalCode"></label>
                                <span asp-validation-for="Input.PostalCode" class="text-danger"></span>
                            </div>

                        </div>

                        <!-- Button -->
                        <div class="mt-4">
                            <button type="submit"
                                    class="w-100 btn btn-primary btn-lg">
                                Complete Registration
                            </button>
                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}