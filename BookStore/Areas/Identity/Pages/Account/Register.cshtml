@page
@model RegisterModel

<div class="card shadow border-0 mt-4">

    <div class="card-header bg-secondary bg-gradient py-4">
        <div class="text-center">
            @if (User.IsInRole(SD.Role_Admin))
            {
                <h2 class="text-white">Register - ADMIN PORTAL</h2>
            }
            else
            {
                <h2 class="text-white">Register</h2>
            }
        </div>
    </div>

    <div class="card-body p-4">

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

            <h4 class="text-secondary text-center mb-4">
                Create a new account
            </h4>

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">

                <!-- Email -->
                <div class="col-12 form-floating">
                    <input asp-for="Input.Email" class="form-control border-0 shadow" placeholder="Email" />
                    <label asp-for="Input.Email" class="ms-2"></label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <!-- Name -->
                <div class="col-md-6 form-floating">
                    <input asp-for="Input.Name" class="form-control border-0 shadow" placeholder="Full Name" />
                    <label asp-for="Input.Name" class="ms-2"></label>
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>

                <!-- Phone -->
                <div class="col-md-6 form-floating">
                    <input asp-for="Input.PhoneNumber" class="form-control border-0 shadow" placeholder="Phone" />
                    <label asp-for="Input.PhoneNumber" class="ms-2"></label>
                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class="col-md-6 form-floating">
                    <input asp-for="Input.Password" class="form-control border-0 shadow" placeholder="Password" />
                    <label asp-for="Input.Password" class="ms-2"></label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <!-- Confirm -->
                <div class="col-md-6 form-floating">
                    <input asp-for="Input.ConfirmPassword" class="form-control border-0 shadow" placeholder="Confirm Password" />
                    <label asp-for="Input.ConfirmPassword" class="ms-2"></label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <!-- Address -->
                <div class="col-md-6 form-floating">
                    <input asp-for="Input.StreetAddress" class="form-control border-0 shadow" placeholder="Street Address" />
                    <label asp-for="Input.StreetAddress" class="ms-2"></label>
                    <span asp-validation-for="Input.StreetAddress" class="text-danger"></span>
                </div>

                <!-- City -->
                <div class="col-md-6 form-floating">
                    <input asp-for="Input.City" class="form-control border-0 shadow" placeholder="City" />
                    <label asp-for="Input.City" class="ms-2"></label>
                    <span asp-validation-for="Input.City" class="text-danger"></span>
                </div>

                <!-- State -->
                <div class="col-md-6 form-floating">
                    <input asp-for="Input.State" class="form-control border-0 shadow" placeholder="State" />
                    <label asp-for="Input.State" class="ms-2"></label>
                    <span asp-validation-for="Input.State" class="text-danger"></span>
                </div>

                <!-- Postal -->
                <div class="col-md-6 form-floating">
                    <input asp-for="Input.PostalCode" class="form-control border-0 shadow" placeholder="Postal Code" />
                    <label asp-for="Input.PostalCode" class="ms-2"></label>
                    <span asp-validation-for="Input.PostalCode" class="text-danger"></span>
                </div>

                <!-- ADMIN -->
                @if (User.IsInRole(SD.Role_Admin))
                {
                    <div class="col-md-6 form-floating">
                        <select asp-for="Input.Role" asp-items="@Model.Input.RoleList"
                                class="form-select border-0 shadow">
                            <option disabled selected>-Select Role-</option>
                        </select>
                        <label class="ms-2">Role</label>
                    </div>

                    <div class="col-md-6 form-floating">
                        <select asp-for="Input.CompanyId"
                                asp-items="@Model.Input.CompanyList"
                                class="form-select border-0 shadow"
                                id="Input_CompanyId"
                                style="display:none;">
                            <option disabled selected>-Select Company-</option>
                        </select>
                        <label class="ms-2">Company</label>
                    </div>
                }

            </div>

            <!-- Button -->
            <div class="mt-4">
                <button id="registerSubmit"
                        type="submit"
                        class="w-100 btn btn-primary">
                    Register
                </button>
            </div>

        </form>

        <!-- External login -->
        @if (!User.IsInRole(SD.Role_Admin))
        {
            <div class="text-center mt-4">
                <p class="text-muted">or</p>

                @if ((Model.ExternalLogins?.Count ?? 0) > 0)
                {
                    <form asp-page="./ExternalLogin"
                          asp-route-returnUrl="@Model.ReturnUrl"
                          method="post">

                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <button type="submit"
                                    class="btn btn-outline-primary me-2"
                                    name="provider"
                                    value="@provider.Name">
                                @provider.DisplayName
                            </button>
                        }

                    </form>
                }
            </div>
        }

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            $('#Input_Role').change(function () {
                var selection = $('#Input_Role option:selected').text();

                if (selection === 'Company') {
                    $('#Input_CompanyId').show();
                } else {
                    $('#Input_CompanyId').hide();
                }
            });
        });
    </script>
}